# ─────────────────────────────────────────────────────────────────────────────
# Example environment file. Copy to .env.local (dev) or .env.production (VPS)
# and replace placeholder values. NEVER commit real secrets — .env.local and
# .env.production are gitignored; this .example file is safe to commit.
#   cp .env.local.example .env.local
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://your_user:your_password@cluster0.xxxxx.mongodb.net/your_db_name?appName=Cluster0

# NextAuth - JWT signing secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=change-me-to-a-random-secret-at-least-32-chars
# NextAuth - full public URL of the app
NEXTAUTH_URL=http://localhost:3000

# SMTP server port (must be 25 for receiving external email)
SMTP_PORT=25
# Hostname that MX records point to
MAIL_SERVER_HOSTNAME=mail.yourdomain.com

# Socket.io server port (runs inside the smtp.js process)
SOCKET_PORT=4000
# Public Socket.io URL the browser connects to (proxied by Caddy in prod)
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# Public IP of this server — used for SPF + website-hosting A records shown in
# each user's domain setup guide. The VPS setup script sets this automatically.
SERVER_PUBLIC_IP=
HOSTING_SERVER_IP=

# ─── OIDC Identity Provider (Sign in with Mailbox) ───
# Base64-encoded RSA PEM key pair used to sign ID tokens (RS256).
# Generate with: npm run generate-keys
OIDC_RSA_PRIVATE_KEY=replace-with-base64-encoded-pem-private-key
OIDC_RSA_PUBLIC_KEY=replace-with-base64-encoded-pem-public-key
# Canonical issuer URL — must stay constant across all custom domains.
OIDC_ISSUER_URL=http://localhost:3000

# ─── SAML SSO signing material ───
# Generate both values with: node scripts/generate-saml-cert.js
SAML_SIGNING_CERT=replace-with-base64-encoded-pem-certificate
SAML_SIGNING_KEY=replace-with-base64-encoded-pem-private-key

# ─────────────────────────────────────────────────────────────────────────────
# Outbound email (send-email feature)
# ─────────────────────────────────────────────────────────────────────────────

# Delivery mode: auto (default) | direct | relay | disabled
#   auto    = use the relay below if set, else deliver direct-to-MX (no relay)
#   direct  = always deliver straight to the recipient's mail server
#   relay   = always use the SMTP relay below
#   disabled= turn outbound sending off (send API returns 503)
# With "auto"/"direct", sending to Gmail/Outlook/etc. works WITHOUT any relay.
OUTBOUND_MODE=auto

# ─── SMTP relay (Next.js process — outbound delivery via nodemailer) ───
# OPTIONAL — only used in auto/relay mode. Leave blank to deliver direct-to-MX.
# Set these if you have a provider (SES/Postmark/Mailgun) for best deliverability.
SMTP_RELAY_HOST=                 # relay hostname, e.g. smtp.your-relay.com
SMTP_RELAY_PORT=587              # relay port, e.g. 587 (STARTTLS) or 465 (TLS)
SMTP_RELAY_USER=                 # relay auth username (if the relay requires auth)
SMTP_RELAY_PASS=                 # relay auth password (if the relay requires auth)
SMTP_RELAY_SECURE=false          # "true" for implicit TLS (port 465), else STARTTLS

# ─── DKIM signing (auto-generated by the setup script) ───
# Publish the printed DNS TXT record (<selector>._domainkey) so Gmail/Outlook
# trust your mail. Sending works without it, but mail may land in spam.
DKIM_DOMAIN=                     # your sending domain, e.g. genuinesoftmart.store
DKIM_SELECTOR=mail               # DKIM selector (DNS host: <selector>._domainkey)
DKIM_PRIVATE_KEY=                # base64-encoded PEM private key (auto-generated)

# ─── Internal emit bridge (BOTH processes — Next.js → smtp-server real-time) ───
# The Socket.io server lives in the smtp-server process, so the Next.js send
# route notifies it over a localhost-only, secret-gated HTTP channel.
# Both processes must share the same INTERNAL_EMIT_SECRET and INTERNAL_EMIT_PORT.
INTERNAL_EMIT_SECRET=change-me-to-a-random-shared-secret
INTERNAL_EMIT_PORT=4001          # localhost port for the emit bridge (default 4001)

# ─── Send rate limiting (Next.js process) ───
# In-memory rolling window, applied per-user and per-mailbox. Note: limits are
# per process instance; behind multiple Next.js instances use a shared store.
SEND_RATE_USER_MAX=50            # max sends per user per window (default 50)
SEND_RATE_MAILBOX_MAX=100        # max sends per mailbox per window (default 100)
SEND_RATE_WINDOW_MS=3600000      # rate window in ms (default 3,600,000 = 1 hour)
